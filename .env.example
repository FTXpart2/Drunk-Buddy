# --- core ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# channel: "local" (terminal) | "twilio" (SMS, any phone) | "bluebubbles" (iMessage)
CHANNEL=local
PORT=8787

# --- state (optional; falls back to in-memory if unset) ---
REDIS_URL=

# --- Twilio (SMS channel) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# In the Twilio console, set the number's "A message comes in" webhook to:
#   <your public url>/sms/incoming   (use ngrok to expose PORT publicly)

# --- BlueBubbles gateway (iMessage; needs a Mac on macOS <= 13 for AppleScript sending) ---
BLUEBUBBLES_SERVER_URL=
BLUEBUBBLES_PASSWORD=
BLUEBUBBLES_METHOD=apple-script
# public https url of THIS backend, used by channel:register
PUBLIC_URL=

# --- sponsors (later phases) ---
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
TOKEN_COMPANY_BASE_URL=
ARIZE_API_KEY=
ARIZE_SPACE_ID=
