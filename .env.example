# --- core ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# channel: "local" (terminal chat) or "bluebubbles" (live iMessage)
CHANNEL=local
PORT=8787

# --- state (optional; falls back to in-memory if unset) ---
REDIS_URL=

# --- BlueBubbles gateway (Phase 0) ---
BLUEBUBBLES_SERVER_URL=
BLUEBUBBLES_PASSWORD=
BLUEBUBBLES_METHOD=apple-script
# public https url of THIS backend (ngrok), used by channel:register
PUBLIC_URL=

# --- heart-rate guardian (Apple Watch -> /watch link -> /vitals) ---
# secret that signs the one-tap health link token (set anything random in prod)
HEALTH_LINK_SECRET=
# bpm thresholds that trigger a proactive check-in while party mode is on
HR_LOW=45
HR_HIGH=130
# how often the heartbeat re-checks open concerns (ms)
HEARTBEAT_MS=30000
# silence after a check-in before escalating to emergency contacts (ms)
ESCALATE_AFTER_MS=300000

# --- sponsors (later phases) ---
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
TOKEN_COMPANY_BASE_URL=
ARIZE_API_KEY=
ARIZE_SPACE_ID=
