# --- core ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# channel: "local" (terminal chat) or "bluebubbles" (live iMessage)
CHANNEL=local
PORT=8787

# --- state (optional; falls back to in-memory if unset) ---
REDIS_URL=

# --- BlueBubbles gateway (Phase 0) ---
BLUEBUBBLES_SERVER_URL=
BLUEBUBBLES_PASSWORD=
BLUEBUBBLES_METHOD=apple-script
# public https url of THIS backend (ngrok), used by channel:register
PUBLIC_URL=

# --- sponsors (later phases) ---
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
TOKEN_COMPANY_BASE_URL=
ARIZE_API_KEY=
ARIZE_SPACE_ID=
