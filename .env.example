# --- core ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# channel: "local" | "telegram" (instant, any phone) | "twilio" (SMS, needs A2P) | "bluebubbles" (iMessage)
CHANNEL=local
PORT=8787

# --- state (optional; falls back to in-memory if unset) ---
REDIS_URL=

# --- Telegram (instant: no tunnel, no registration, no cost) ---
# Create a bot via @BotFather in Telegram (/newbot), paste the token here, set CHANNEL=telegram.
TELEGRAM_BOT_TOKEN=

# --- Twilio (SMS channel; US sending requires A2P 10DLC registration) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Set the number's "A message comes in" webhook to <public url>/sms/incoming (use cloudflared)

# --- BlueBubbles gateway (iMessage; AppleScript sending broken on macOS 14+) ---
BLUEBUBBLES_SERVER_URL=
BLUEBUBBLES_PASSWORD=
BLUEBUBBLES_METHOD=apple-script
# PUBLIC_URL must be reachable from your phone (the Mac's LAN url, e.g.
# http://192.168.12.130:8787) so the buddy's one-tap /watch health link opens.
PUBLIC_URL=

# --- heart-rate guardian (Apple Watch -> /watch link -> /vitals) ---
HEALTH_LINK_SECRET=
HR_LOW=45
HR_HIGH=130
HEARTBEAT_MS=30000
ESCALATE_AFTER_MS=300000

# --- sponsors (later phases) ---
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
TOKEN_COMPANY_BASE_URL=
ARIZE_API_KEY=
ARIZE_SPACE_ID=
